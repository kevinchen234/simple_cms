<%= link_to("<< Back to List", pages_path, :class => 'back-link') %>

<div class="pages delete">
  <h2>Delete Page</h2>

  <%= form_for(@page, :method => 'delete') do |f| %>

  <p>Delete this page?</p>
  <p>Are you sure you want to proceed? <%= @page.name %> will be permanently deleted.</p>


    <div class="form-buttons">
      <%= f.submit("Delete Page") %>
    </div>

  <% end %>
</div>
